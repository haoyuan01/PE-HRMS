# ---------------------------------------------------------------------------
# Environment variables for PE-HRMS
# Copy this file to `.env.local` for local development, and set the same
# variables in the Vercel dashboard (Project → Settings → Environment Variables)
# for production / preview deployments.
# ---------------------------------------------------------------------------

# Base URL of the external backend REST API.
# Used SERVER-SIDE only, by the Next.js route handlers in app/api/* (login,
# session, logout, forgot-password and the /api/proxy/[...path] proxy).
# Because it is not prefixed with NEXT_PUBLIC_, it is never exposed to the
# browser — the client talks to same-origin /api/* routes that forward here.
# Example: https://api.your-hrms-backend.com
API_BASE_URL=

# ---------------------------------------------------------------------------
# Optional / not currently referenced in code (documented in CLAUDE.md).
# Uncomment and set only if you wire client-side calls directly to the backend.
# NEXT_PUBLIC_API_BASE_URL=
# NEXT_PUBLIC_APP_ENV=production
